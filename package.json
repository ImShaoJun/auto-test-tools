{
  "name": "karate-mcp-server",
  "version": "2.0.0",
  "description": "MCP Server for BDD automated API testing — pure TypeScript engine with Karate-style DSL, no Java dependency",
  "type": "module",
  "bin": {
    "karate-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "karate",
    "bdd",
    "testing",
    "automation",
    "cucumber",
    "gherkin"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@cucumber/gherkin": "^29.0.0",
    "@cucumber/messages": "^26.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
